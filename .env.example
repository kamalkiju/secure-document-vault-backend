# Secure Document Vault Platform - Environment Configuration
# Copy to .env and set values. Never commit .env to version control.

# Server
NODE_ENV=development
PORT=3000

# CORS (allowed frontend origin; no open CORS)
ALLOWED_ORIGIN=http://localhost:3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Database (SQLite path)
DATABASE_PATH=./data/vault.db

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate limiting
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_UPLOAD_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_MS=60000

# Upload
UPLOAD_MAX_FILE_SIZE_MB=100
UPLOAD_ALLOWED_MIMES=application/pdf,image/jpeg,image/png,image/gif,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Storage (local path for uploaded files - must be outside web root)
UPLOAD_STORAGE_PATH=./data/uploads

# Logging
LOG_LEVEL=info
